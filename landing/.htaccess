# hollr.to — Apache routing rules for SiteGround
#
# Routing strategy:
#   /                     → index.html  (landing page)
#   /auth/verify          → auth/verify.html
#   /auth/verify.html     → auth/verify.html (direct access)
#   /:handle              → handle/index.html (the canvas for that handle)
#
# API calls go to api.hollr.to (separate Fly.io backend via CNAME).
# Static assets (css, js, images) are served normally.

Options -Indexes
RewriteEngine On

# ── Serve auth pages directly ─────────────────────────────────────────────────
RewriteRule ^auth/verify/?$  auth/verify.html [L]

# ── Serve static assets as-is ────────────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Route handles to the canvas ───────────────────────────────────────────────
# Everything that doesn't match a file or directory (and isn't 'auth')
# is treated as a :handle and served the canvas page.
RewriteCond %{REQUEST_URI} !^/auth/
RewriteRule ^([a-zA-Z0-9_-]+)/?$  handle/index.html [L]

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Compression ───────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# ── Cache static assets ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css  "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>
