# hollr.to backend — environment variables
# Copy to .env and fill in values before running

# HTTP port (Fly.io sets this automatically)
PORT=3000

# Absolute path for SQLite database and uploaded files
# On Fly.io: /data  (persistent volume)
DATA_DIR=/data

# Server-side secret for AES-256 encryption of Resend API keys
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=CHANGE_ME_generate_with_openssl_rand_-hex_32

# Resend API key used for platform magic-link emails (Paul's key)
PLATFORM_RESEND_KEY=re_YOUR_RESEND_API_KEY_HERE

# "From" address for platform emails (must be on verified Resend domain)
PLATFORM_FROM_EMAIL=hollr <to@up.paulfleury.com>

# Public URL of this backend (used to build upload file URLs)
BASE_URL=https://api.hollr.to

# Public URL of the frontend (used to build magic links)
FRONTEND_URL=https://hollr.to

# Extra allowed CORS origins (comma-separated, no spaces)
ALLOWED_ORIGINS=

# Node environment
NODE_ENV=production
